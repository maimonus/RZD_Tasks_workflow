# Render Backend Environment Variables
# 1. DATABASE_URL получите из Render PostgreSQL → Internal URL
# 2. JWT_SECRET измените на свой секретный ключ

DATABASE_URL=postgresql://render_user:render_pass@hostname:5432/rzd_db
JWT_SECRET=RZD_WORKFLOW_SUPER_SECRET_TOKEN_2024_change_prod
JWT_EXPIRES_MINUTES
